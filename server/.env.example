PORT=5000
HOST=0.0.0.0
NODE_ENV=development

# Auth
STAFF_PIN=1234

# Database (SQLite default, or set DATABASE_URL for PostgreSQL)
DATABASE_PATH=./data/hotel.sqlite
# DATABASE_URL=postgresql://user:pass@localhost/hotel

# Public URL for QR code generation
PUBLIC_BASE_URL=http://localhost:5173

# Cloudinary (optional – leave blank to use inline base64 fallback)
CLOUDINARY_URL=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=qr-menu

# Telegram notifications (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Grok AI (optional)
GROK_API_KEY=
XAI_API_KEY=
GROK_MODEL=grok-4-latest
GROK_IMAGE_MODEL=grok-2-image-latest
